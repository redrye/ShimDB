{
  "name": "ShimDB",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run development",
    "development": "npx mix --mix-config=./webpack.mix.js",
    "watch": "npx mix --mix-config=./webpack.mix.js  watch",
    "watch-poll": " npx mix watch -- --watch-options-poll=1000",
    "hot": "npx mix watch --hot",
    "prod": "npm run production",
    "production": "npx mix --mix-config=./webpack.mix.js --production"
  },
  "devDependencies": {
    "axios": "^0.19",
    "cross-env": "^7.0",
    "laravel-mix": "^5.0.9",
    "lodash": "^4.17.19",
    "resolve-url-loader": "^3.1.0",
    "sass": "^1.15.2",
    "sass-loader": "^8.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vue-template-compiler": "^2.7.16",
    "webpack-cli": "^7.0.0"
  }
}
